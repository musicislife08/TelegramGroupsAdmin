@inject IConfigService ConfigService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        @switch (ComponentType)
        {
            case var t when t == typeof(ContentDetectionStopWords):
                <ContentDetectionStopWords @ref="_stopWords" Chat="@Chat" />
                break;
            case var t when t == typeof(ContentDetectionSimilarity):
                <ContentDetectionSimilarity @ref="_similarity" Chat="@Chat" />
                break;
            case var t when t == typeof(ContentDetectionBayes):
                <ContentDetectionBayes @ref="_bayes" Chat="@Chat" />
                break;
            case var t when t == typeof(ContentDetectionSpacing):
                <ContentDetectionSpacing @ref="_spacing" Chat="@Chat" />
                break;
            case var t when t == typeof(ContentDetectionInvisibleChars):
                <ContentDetectionInvisibleChars @ref="_invisibleChars" Chat="@Chat" />
                break;
            case var t when t == typeof(ContentDetectionTranslation):
                <ContentDetectionTranslation @ref="_translation" Chat="@Chat" />
                break;
            case var t when t == typeof(ContentDetectionOpenAI):
                <ContentDetectionOpenAI @ref="_openAI" Chat="@Chat" />
                break;
            case var t when t == typeof(ContentDetectionImage):
                <ContentDetectionImage @ref="_image" Chat="@Chat" />
                break;
            case var t when t == typeof(ContentDetectionVideo):
                <ContentDetectionVideo @ref="_video" Chat="@Chat" />
                break;
            default:
                <MudAlert Severity="Severity.Error" Class="ma-4">
                    Unknown detection component type. Please refresh the page and try again.
                </MudAlert>
                break;
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="@SaveAndClose" Disabled="@_isSaving">
            @if (_isSaving)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                <span class="ml-2">Saving...</span>
            }
            else
            {
                <text>Save</text>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public ChatIdentity? Chat { get; set; }

    [Parameter]
    public Type ComponentType { get; set; } = null!;

    private ContentDetectionStopWords? _stopWords;
    private ContentDetectionSimilarity? _similarity;
    private ContentDetectionBayes? _bayes;
    private ContentDetectionSpacing? _spacing;
    private ContentDetectionInvisibleChars? _invisibleChars;
    private ContentDetectionTranslation? _translation;
    private ContentDetectionOpenAI? _openAI;
    private ContentDetectionImage? _image;
    private ContentDetectionVideo? _video;

    private bool _isSaving;

    private IDetectionConfigComponent? GetActiveComponent() => ComponentType switch
    {
        var t when t == typeof(ContentDetectionStopWords) => _stopWords,
        var t when t == typeof(ContentDetectionSimilarity) => _similarity,
        var t when t == typeof(ContentDetectionBayes) => _bayes,
        var t when t == typeof(ContentDetectionSpacing) => _spacing,
        var t when t == typeof(ContentDetectionInvisibleChars) => _invisibleChars,
        var t when t == typeof(ContentDetectionTranslation) => _translation,
        var t when t == typeof(ContentDetectionOpenAI) => _openAI,
        var t when t == typeof(ContentDetectionImage) => _image,
        var t when t == typeof(ContentDetectionVideo) => _video,
        _ => null
    };

    private void Cancel() => MudDialog.Cancel();

    private async Task SaveAndClose()
    {
        if (_isSaving) return;

        try
        {
            _isSaving = true;

            var component = GetActiveComponent();
            if (component is null)
            {
                Snackbar.Add("No configuration component is active", Severity.Error);
                return;
            }

            var config = component.GetConfig();
            var chat = Chat ?? ChatIdentity.FromId(0);
            await ConfigService.SaveAsync(ConfigType.ContentDetection, chat, config);
            Snackbar.Add(chat.Id == 0 ? "Global configuration saved successfully" : "Chat configuration saved successfully", Severity.Success);

            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error saving configuration: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSaving = false;
        }
    }
}
