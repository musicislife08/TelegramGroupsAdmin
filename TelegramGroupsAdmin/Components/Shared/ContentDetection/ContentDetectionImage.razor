@implements IDetectionConfigComponent
@inject IConfigService ConfigService
@inject ISnackbar Snackbar

<MudPaper Class="pa-4" Elevation="1">
    <MudStack Spacing="3">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
            <MudText Typo="Typo.h6" Color="Color.Primary">Image Spam Detection</MudText>
            <HelpTooltip Text="3-layer image analysis pipeline: Layer 1 (Hash Similarity) compares against known spam images. Layer 2 (OCR) extracts text and runs text-based spam checks. Layer 3 (AI Vision) uses OpenAI for comprehensive analysis. Each layer can short-circuit if confident enough." />
        </MudStack>

        @if (!IsGlobalView)
        {
            <!--suppress CssUnresolvedCustomProperty -->
            <MudPaper Class="pa-3" Elevation="0" Style="background-color: var(--mud-palette-background-grey)">
                <MudSwitch T="bool" @bind-Value="_config.ImageSpam.UseGlobal"
                          Label="@(_config.ImageSpam.UseGlobal ? "Using Global Settings" : "Using Custom Settings")"
                          Color="@(_config.ImageSpam.UseGlobal ? Color.Default : Color.Primary)" />
                @if (_config.ImageSpam.UseGlobal)
                {
                    <MudText Typo="Typo.caption" Class="mt-1">
                        This chat is using the global image spam configuration. Toggle off to customize.
                    </MudText>
                }
            </MudPaper>
        }

        @{
            var activeConfig = (IsGlobalView || !_config.ImageSpam.UseGlobal) ? _config.ImageSpam : _globalConfig.ImageSpam;
            var isReadOnly = !IsGlobalView && _config.ImageSpam.UseGlobal;
        }

        <MudSwitch T="bool" @bind-Value="activeConfig.Enabled"
                  Label="Enable Image Spam Detection"
                  Color="Color.Primary"
                  Disabled="@isReadOnly" />

        @if (activeConfig.Enabled)
        {
            <MudText Typo="Typo.subtitle2" Class="mt-2">Detection Layers</MudText>

            <MudSwitch T="bool" @bind-Value="activeConfig.UseHashSimilarity"
                      Label="Layer 1: Hash Similarity"
                      Color="Color.Primary"
                      Disabled="@isReadOnly" />
            <MudText Typo="Typo.caption" Class="ml-8 mud-text-secondary">
                Compare image hashes against known spam training samples (fastest, no API cost)
            </MudText>

            <MudSwitch T="bool" @bind-Value="activeConfig.UseOCR"
                      Label="Layer 2: OCR Text Extraction"
                      Color="Color.Primary"
                      Disabled="@isReadOnly" />
            <MudText Typo="Typo.caption" Class="ml-8 mud-text-secondary">
                Extract text from images and run text-based spam checks (fast, no API cost)
            </MudText>

            <MudSwitch T="bool" @bind-Value="activeConfig.UseOpenAIVision"
                      Label="Layer 3: AI Vision Analysis"
                      Color="Color.Primary"
                      Disabled="@isReadOnly" />
            <MudText Typo="Typo.caption" Class="ml-8 mud-text-secondary">
                Use OpenAI Vision for comprehensive image analysis (slow, API costs apply)
            </MudText>

            <MudDivider Class="my-2" />
            <MudText Typo="Typo.subtitle2">Thresholds</MudText>

            <MudGrid>
                <MudItem xs="12" md="6">
                    <FieldWithHelp HelpText="If OCR text-based spam checks return confidence >= this threshold, skip the expensive Vision API call. Higher = more Vision calls, lower = more OCR-only decisions.">
                        <MudNumericField @bind-Value="activeConfig.OcrConfidenceThreshold"
                                        Label="OCR Confidence Threshold"
                                        Min="0.0" Max="5.0" Step="0.25"
                                        Disabled="@isReadOnly"
                                        HelperText="@(isReadOnly ? $"Using global: {activeConfig.OcrConfidenceThreshold:F2}" : "Skip Vision if OCR text checks score >= this (0.0-5.0)")" />
                    </FieldWithHelp>
                </MudItem>
                <MudItem xs="12" md="6">
                    <FieldWithHelp HelpText="Minimum characters extracted by OCR before attempting text-based spam analysis. Too short = not enough context.">
                        <MudNumericField @bind-Value="activeConfig.MinOcrTextLength"
                                        Label="Min OCR Text Length"
                                        Min="1" Max="100"
                                        Disabled="@isReadOnly"
                                        HelperText="@(isReadOnly ? $"Using global: {activeConfig.MinOcrTextLength}" : "Minimum extracted characters for text analysis")" />
                    </FieldWithHelp>
                </MudItem>
                <MudItem xs="12" md="6">
                    <FieldWithHelp HelpText="Minimum perceptual hash similarity (0.0-1.0) to match against spam training samples. Higher = stricter (fewer false positives).">
                        <MudNumericField @bind-Value="activeConfig.HashSimilarityThreshold"
                                        Label="Hash Similarity Threshold"
                                        Min="0.5" Max="1.0" Step="0.01"
                                        Disabled="@isReadOnly"
                                        HelperText="@(isReadOnly ? $"Using global: {activeConfig.HashSimilarityThreshold:F2}" : "Similarity score to count as a match")" />
                    </FieldWithHelp>
                </MudItem>
                <MudItem xs="12" md="6">
                    <FieldWithHelp HelpText="Confidence level assigned when a hash matches a known spam sample. Should be high since hash matches are reliable.">
                        <MudNumericField @bind-Value="activeConfig.HashMatchConfidence"
                                        Label="Hash Match Confidence (%)"
                                        Min="50" Max="100"
                                        Disabled="@isReadOnly"
                                        HelperText="@(isReadOnly ? $"Using global: {activeConfig.HashMatchConfidence}%" : "Confidence when hash matches training sample")" />
                    </FieldWithHelp>
                </MudItem>
                <MudItem xs="12" md="6">
                    <FieldWithHelp HelpText="Maximum training samples to compare against. Limits database query size for performance.">
                        <MudNumericField @bind-Value="activeConfig.MaxTrainingSamplesToCompare"
                                        Label="Max Training Samples"
                                        Min="100" Max="10000"
                                        Disabled="@isReadOnly"
                                        HelperText="@(isReadOnly ? $"Using global: {activeConfig.MaxTrainingSamplesToCompare}" : "Max samples for hash comparison")" />
                    </FieldWithHelp>
                </MudItem>
            </MudGrid>
        }

        @if (!IsGlobalView && !_config.ImageSpam.UseGlobal && _globalConfig.ImageSpam.Enabled != _config.ImageSpam.Enabled)
        {
            <MudAlert Severity="Severity.Info" Dense="true">
                Global setting: @(_globalConfig.ImageSpam.Enabled ? "Enabled" : "Disabled")
            </MudAlert>
        }
    </MudStack>
</MudPaper>

@code {
    [Parameter]
    public ChatIdentity? Chat { get; set; }

    private ContentDetectionConfig _config = new();
    private ContentDetectionConfig _globalConfig = new();
    private bool IsGlobalView => Chat is null || Chat.Id == 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadConfiguration();
    }

    private async Task LoadConfiguration()
    {
        try
        {
            _globalConfig = await ConfigService.GetAsync<ContentDetectionConfig>(ConfigType.ContentDetection, 0)
                            ?? new ContentDetectionConfig();

            if (IsGlobalView)
            {
                _config = _globalConfig;
            }
            else
            {
                var chatConfig = await ConfigService.GetAsync<ContentDetectionConfig>(ConfigType.ContentDetection, Chat!.Id);
                _config = chatConfig ?? new ContentDetectionConfig();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading configuration: {ex.Message}", Severity.Error);
            _config = new ContentDetectionConfig();
            _globalConfig = new ContentDetectionConfig();
        }
    }

    public ContentDetectionConfig GetConfig()
    {
        if (IsGlobalView)
        {
            _config.ImageSpam.UseGlobal = true;
        }

        return _config;
    }
}
