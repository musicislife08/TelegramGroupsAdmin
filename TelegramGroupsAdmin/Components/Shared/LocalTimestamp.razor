@if (UserTimeZone is not null)
{
    var displayTime = TimeZoneInfo.ConvertTime(Value, UserTimeZone);
    <span>@displayTime.ToString(Format)</span>
}
else
{
    <span>&mdash;</span>
}

@code {
    [Parameter, EditorRequired]
    public DateTimeOffset Value { get; set; }

    [Parameter]
    public string Format { get; set; } = "MMM d, yyyy h:mm tt";

    [CascadingParameter]
    private TimeZoneInfo? UserTimeZone { get; set; }
}
