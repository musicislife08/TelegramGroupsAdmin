@page "/users"
@attribute [Authorize]
@implements IDisposable
@using TelegramGroupsAdmin.Components.Shared.Settings
@using TelegramGroupsAdmin.Core.Extensions
@using TelegramGroupsAdmin.Core.Models
@using TelegramGroupsAdmin.Telegram.Models
@inject ITelegramUserManagementService UserManagementService
@inject IManagedChatsRepository ManagedChatsRepository
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Users - TelegramGroupsAdmin</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="mt-4">
    <MudText Typo="Typo.h4" GutterBottom="true">Telegram Users</MudText>
    <MudText Typo="Typo.body1" Class="mb-4">Manage Telegram users across all monitored chats</MudText>

    @* Search Bar *@
    <MudPaper Class="pa-4 mb-4" Elevation="1">
        <MudTextField @bind-Value="_searchText"
                      Label="Search users"
                      Placeholder="Search by name, username, or ID..."
                      Variant="Variant.Outlined"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Immediate="true"
                      DebounceInterval="300"
                      OnDebounceIntervalElapsed="OnSearchChanged"
                      Clearable="true"
                      OnClearButtonClick="@(() => { _searchText = string.Empty; OnSearchChanged(); })" />
    </MudPaper>

    @if (_loading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
    }

    <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" TabPanelsClass="pa-6">
        <MudTabPanel Text="Active" Icon="@Icons.Material.Filled.People" BadgeData="@_tabCounts.ActiveCount">
            <MudTable T="TelegramUserListItem"
                     @ref="_activeTable"
                     ServerData="@LoadActiveServerDataAsync"
                     Hover="true" Breakpoint="Breakpoint.Sm" Dense="true">
                <HeaderContent>
                    <MudTh><MudTableSortLabel T="TelegramUserListItem" SortLabel="User">User</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel T="TelegramUserListItem" SortLabel="Status">Status</MudTableSortLabel></MudTh>
                    <MudTh>Chats</MudTh>
                    <MudTh>Warnings</MudTh>
                    <MudTh><MudTableSortLabel T="TelegramUserListItem" SortLabel="LastSeen">Last Seen</MudTableSortLabel></MudTh>
                    <MudTh>Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="User">
                        <UserInfoCell User="context" />
                    </MudTd>
                    <MudTd DataLabel="Status">
                        <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(context.Status)">
                            @GetStatusIcon(context.Status) @context.Status.ToString()
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="Chats">@context.ChatCount</MudTd>
                    <MudTd DataLabel="Warnings">
                        @if (context.WarningCount > 0)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Warning">@context.WarningCount</MudChip>
                        }
                        else
                        {
                            <MudText Typo="Typo.caption" Color="Color.Secondary">None</MudText>
                        }
                    </MudTd>
                    <MudTd DataLabel="Last Seen">
                        <LocalTimestamp Value="@context.LastSeenAt" />
                    </MudTd>
                    <MudTd DataLabel="Actions">
                        <MudTooltip Text="View Details">
                            <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" OnClick="@(() => ViewUserDetail(context.TelegramUserId))" />
                        </MudTooltip>
                        <MudTooltip Text="@(context.IsTrusted ? "Remove Trust" : "Trust User")">
                            <MudIconButton Icon="@(context.IsTrusted ? Icons.Material.Filled.PersonOff : Icons.Material.Filled.VerifiedUser)"
                                          Size="Size.Small"
                                          Color="@(context.IsTrusted ? Color.Default : Color.Success)"
                                          OnClick="@(() => ToggleTrust(context))" />
                        </MudTooltip>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager PageSizeOptions="[25, 50, 100]" />
                </PagerContent>
            </MudTable>
        </MudTabPanel>

        <MudTabPanel Text="Tagged" Icon="@Icons.Material.Filled.LocalOffer" BadgeData="@_tabCounts.TaggedCount" BadgeColor="Color.Warning">
            <MudTable T="TelegramUserListItem"
                     @ref="_taggedTable"
                     ServerData="@LoadTaggedServerDataAsync"
                     Hover="true" Breakpoint="Breakpoint.Sm" Dense="true">
                <HeaderContent>
                    <MudTh><MudTableSortLabel T="TelegramUserListItem" SortLabel="User">User</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel T="TelegramUserListItem" SortLabel="Status">Status</MudTableSortLabel></MudTh>
                    <MudTh>Warnings</MudTh>
                    <MudTh><MudTableSortLabel T="TelegramUserListItem" SortLabel="LastSeen">Last Seen</MudTableSortLabel></MudTh>
                    <MudTh>Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="User">
                        <UserInfoCell User="context" />
                    </MudTd>
                    <MudTd DataLabel="Status">
                        <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(context.Status)">
                            @GetStatusIcon(context.Status) @context.Status.ToString()
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="Warnings">
                        <MudChip T="string" Size="Size.Small" Color="Color.Warning">@context.WarningCount</MudChip>
                    </MudTd>
                    <MudTd DataLabel="Last Seen">
                        <LocalTimestamp Value="@context.LastSeenAt" />
                    </MudTd>
                    <MudTd DataLabel="Actions">
                        <MudTooltip Text="View Details">
                            <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" OnClick="@(() => ViewUserDetail(context.TelegramUserId))" />
                        </MudTooltip>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager PageSizeOptions="[25, 50, 100]" />
                </PagerContent>
            </MudTable>
        </MudTabPanel>

        <MudTabPanel Text="Trusted" Icon="@Icons.Material.Filled.VerifiedUser" BadgeData="@_tabCounts.TrustedCount" BadgeColor="Color.Success">
            <MudTable T="TelegramUserListItem"
                     @ref="_trustedTable"
                     ServerData="@LoadTrustedServerDataAsync"
                     Hover="true" Breakpoint="Breakpoint.Sm" Dense="true">
                <HeaderContent>
                    <MudTh><MudTableSortLabel T="TelegramUserListItem" SortLabel="User">User</MudTableSortLabel></MudTh>
                    <MudTh>Chats</MudTh>
                    <MudTh><MudTableSortLabel T="TelegramUserListItem" SortLabel="LastSeen">Last Seen</MudTableSortLabel></MudTh>
                    <MudTh>Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="User">
                        <UserInfoCell User="context" />
                    </MudTd>
                    <MudTd DataLabel="Chats">@context.ChatCount</MudTd>
                    <MudTd DataLabel="Last Seen">
                        <LocalTimestamp Value="@context.LastSeenAt" />
                    </MudTd>
                    <MudTd DataLabel="Actions">
                        <MudTooltip Text="View Details">
                            <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" OnClick="@(() => ViewUserDetail(context.TelegramUserId))" />
                        </MudTooltip>
                        <MudTooltip Text="Remove Trust">
                            <MudIconButton Icon="@Icons.Material.Filled.PersonOff" Size="Size.Small" OnClick="@(() => ToggleTrust(context))" />
                        </MudTooltip>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager PageSizeOptions="[25, 50, 100]" />
                </PagerContent>
            </MudTable>
        </MudTabPanel>

        <MudTabPanel Text="Banned" Icon="@Icons.Material.Filled.Block" BadgeData="@_tabCounts.BannedCount" BadgeColor="Color.Error">
            <MudTable T="BannedUserListItem"
                     @ref="_bannedTable"
                     ServerData="@LoadBannedServerDataAsync"
                     Hover="true" Breakpoint="Breakpoint.Sm" Dense="true">
                <HeaderContent>
                    <MudTh><MudTableSortLabel T="BannedUserListItem" SortLabel="User">User</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel T="BannedUserListItem" SortLabel="BannedAt" InitialDirection="SortDirection.Descending">Banned</MudTableSortLabel></MudTh>
                    <MudTh>Expires</MudTh>
                    <MudTh>Warnings</MudTh>
                    <MudTh>Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="User">
                        <UserInfoCell User="context" />
                    </MudTd>
                    <MudTd DataLabel="Banned">
                        @if (context.BannedAt.HasValue)
                        {
                            <LocalTimestamp Value="@context.BannedAt.Value" />
                        }
                        else
                        {
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Unknown</MudText>
                        }
                    </MudTd>
                    <MudTd DataLabel="Expires">
                        @if (context.IsPermanentBan)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Error">Permanent</MudChip>
                        }
                        else if (context.BanExpires.HasValue)
                        {
                            var timeRemaining = context.BanExpires.Value - DateTimeOffset.UtcNow;
                            @if (timeRemaining.TotalDays > 1)
                            {
                                <MudText Typo="Typo.body2">@($"{(int)timeRemaining.TotalDays}d {timeRemaining.Hours}h")</MudText>
                            }
                            else if (timeRemaining.TotalHours > 1)
                            {
                                <MudText Typo="Typo.body2">@($"{(int)timeRemaining.TotalHours}h {timeRemaining.Minutes}m")</MudText>
                            }
                            else
                            {
                                <MudText Typo="Typo.body2">@($"{(int)timeRemaining.TotalMinutes}m")</MudText>
                            }
                        }
                    </MudTd>
                    <MudTd DataLabel="Warnings">
                        @if (context.WarningCount > 0)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Warning">@context.WarningCount</MudChip>
                        }
                        else
                        {
                            <MudText Typo="Typo.caption" Color="Color.Secondary">None</MudText>
                        }
                    </MudTd>
                    <MudTd DataLabel="Actions">
                        <MudTooltip Text="Unban User">
                            <MudIconButton Icon="@Icons.Material.Filled.CheckCircle"
                                          Size="Size.Small"
                                          Color="Color.Success"
                                          OnClick="@(() => UnbanUser(context))" />
                        </MudTooltip>
                        <MudTooltip Text="View Details">
                            <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" OnClick="@(() => ViewUserDetail(context.TelegramUserId))" />
                        </MudTooltip>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager PageSizeOptions="[25, 50, 100]" />
                </PagerContent>
            </MudTable>
        </MudTabPanel>

        <MudTabPanel Text="Kicked" Icon="@Icons.Material.Filled.PersonRemove" BadgeData="@_tabCounts.KickedCount" BadgeColor="Color.Default">
            <MudText Typo="Typo.body2" Class="mb-4" Color="Color.Secondary">
                Users who were removed from the group but not banned. Typically from failed welcome verification or admin kicks.
            </MudText>
            <MudTable T="TelegramUserListItem"
                     @ref="_kickedTable"
                     ServerData="@LoadKickedServerDataAsync"
                     Hover="true" Breakpoint="Breakpoint.Sm" Dense="true">
                <HeaderContent>
                    <MudTh><MudTableSortLabel T="TelegramUserListItem" SortLabel="User">User</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel T="TelegramUserListItem" SortLabel="LastSeen">Joined</MudTableSortLabel></MudTh>
                    <MudTh>Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="User">
                        <UserInfoCell User="context" ShowBadges="false" />
                    </MudTd>
                    <MudTd DataLabel="Joined">
                        <LocalTimestamp Value="@context.LastSeenAt" />
                    </MudTd>
                    <MudTd DataLabel="Actions">
                        <MudTooltip Text="View Details">
                            <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" OnClick="@(() => ViewUserDetail(context.TelegramUserId))" />
                        </MudTooltip>
                        <MudTooltip Text="Trust User">
                            <MudIconButton Icon="@Icons.Material.Filled.VerifiedUser"
                                          Size="Size.Small"
                                          Color="Color.Success"
                                          OnClick="@(() => ToggleTrust(context))" />
                        </MudTooltip>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager PageSizeOptions="[25, 50, 100]" />
                </PagerContent>
            </MudTable>
        </MudTabPanel>

        <MudTabPanel Text="Tags" Icon="@Icons.Material.Filled.LocalOffer">
            <TagManagement />
        </MudTabPanel>
    </MudTabs>
</MudContainer>

@code {
    [CascadingParameter] private WebUserIdentity? WebUser { get; set; }

    // Table refs for server-side data reload
    private MudTable<TelegramUserListItem> _activeTable = null!;
    private MudTable<TelegramUserListItem> _taggedTable = null!;
    private MudTable<TelegramUserListItem> _trustedTable = null!;
    private MudTable<BannedUserListItem> _bannedTable = null!;
    private MudTable<TelegramUserListItem> _kickedTable = null!;

    private UserTabCounts _tabCounts = new();
    private List<long>? _chatIds;
    private bool _loading = true;
    private string _searchText = string.Empty;
    private CancellationTokenSource _searchCts = new();

    protected override async Task OnInitializedAsync()
    {
        if (WebUser is null) return;

        // Load accessible chats once
        var accessibleChats = await ManagedChatsRepository.GetUserAccessibleChatsAsync(
            WebUser.Id,
            WebUser.PermissionLevel);
        _chatIds = accessibleChats.Select(c => c.Identity.Id).ToList();

        // Empty list means all chats (GlobalAdmin/Owner) — normalize to null
        if (_chatIds.Count == 0)
            _chatIds = null;

        // Load tab counts (tables load lazily via ServerData)
        _tabCounts = await UserManagementService.GetUserTabCountsAsync(_chatIds, null);
        _loading = false;
    }

    // ============================================================================
    // ServerData Callbacks
    // ============================================================================

    private Task<TableData<TelegramUserListItem>> LoadActiveServerDataAsync(TableState state, CancellationToken ct)
        => LoadUsersServerDataAsync(UserListFilter.Active, state, ct);

    private Task<TableData<TelegramUserListItem>> LoadTaggedServerDataAsync(TableState state, CancellationToken ct)
        => LoadUsersServerDataAsync(UserListFilter.Tagged, state, ct);

    private Task<TableData<TelegramUserListItem>> LoadTrustedServerDataAsync(TableState state, CancellationToken ct)
        => LoadUsersServerDataAsync(UserListFilter.Trusted, state, ct);

    private Task<TableData<TelegramUserListItem>> LoadKickedServerDataAsync(TableState state, CancellationToken ct)
        => LoadUsersServerDataAsync(UserListFilter.Kicked, state, ct);

    private async Task<TableData<TelegramUserListItem>> LoadUsersServerDataAsync(
        UserListFilter filter, TableState state, CancellationToken cancellationToken)
    {
        try
        {
            var (items, totalCount) = await UserManagementService.GetPagedUsersAsync(
                filter,
                skip: state.Page * state.PageSize,
                take: state.PageSize,
                searchText: string.IsNullOrWhiteSpace(_searchText) ? null : _searchText,
                chatIds: _chatIds,
                sortLabel: state.SortLabel,
                sortDescending: state.SortDirection == SortDirection.Descending,
                cancellationToken: cancellationToken);

            return new TableData<TelegramUserListItem> { Items = items, TotalItems = totalCount };
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading users: {ex.Message}", Severity.Error);
            return new TableData<TelegramUserListItem> { Items = [], TotalItems = 0 };
        }
    }

    private async Task<TableData<BannedUserListItem>> LoadBannedServerDataAsync(TableState state, CancellationToken cancellationToken)
    {
        try
        {
            var (items, totalCount) = await UserManagementService.GetPagedBannedUsersWithDetailsAsync(
                skip: state.Page * state.PageSize,
                take: state.PageSize,
                searchText: string.IsNullOrWhiteSpace(_searchText) ? null : _searchText,
                sortLabel: state.SortLabel,
                sortDescending: state.SortDirection == SortDirection.Descending,
                cancellationToken: cancellationToken);

            return new TableData<BannedUserListItem> { Items = items, TotalItems = totalCount };
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading banned users: {ex.Message}", Severity.Error);
            return new TableData<BannedUserListItem> { Items = [], TotalItems = 0 };
        }
    }

    // ============================================================================
    // Search
    // ============================================================================

    private async void OnSearchChanged()
    {
        // Cancel any previous search
        await _searchCts.CancelAsync();
        _searchCts.Dispose();
        _searchCts = new CancellationTokenSource();

        try
        {
            // Refresh tab counts with search filter
            _tabCounts = await UserManagementService.GetUserTabCountsAsync(
                _chatIds,
                string.IsNullOrWhiteSpace(_searchText) ? null : _searchText,
                _searchCts.Token);

            // Reload all visible tables
            await ReloadAllTablesAsync();
            StateHasChanged();
        }
        catch (OperationCanceledException)
        {
            return; // Debounced search superseded by a newer keystroke
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error searching: {ex.Message}", Severity.Error);
        }
    }

    // ============================================================================
    // Actions
    // ============================================================================

    private async Task ToggleTrust(TelegramUserListItem user)
    {
        try
        {
            var executor = WebUser!.ToActor();

            var action = user.IsTrusted ? "remove trust from" : "trust";
            var success = await UserManagementService.ToggleTrustAsync(user.TelegramUserId, executor);

            if (success)
            {
                Snackbar.Add($"Successfully {action}ed {user.DisplayName}", Severity.Success);
                await RefreshAfterActionAsync();
            }
            else
            {
                Snackbar.Add($"Failed to {action} {user.DisplayName}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error toggling trust: {ex.Message}", Severity.Error);
        }
    }

    private async Task UnbanUser(BannedUserListItem user)
    {
        try
        {
            var confirmed = await DialogService.ShowMessageBoxAsync(
                "Confirm Unban",
                $"Are you sure you want to unban {user.DisplayName}?",
                yesText: "Unban",
                cancelText: "Cancel");

            if (confirmed != true)
                return;

            var executor = WebUser!.ToActor();

            var success = await UserManagementService.UnbanAsync(user.TelegramUserId, executor, reason: "Unbanned from web interface");

            if (success)
            {
                Snackbar.Add($"Successfully unbanned {user.DisplayName}", Severity.Success);
                await RefreshAfterActionAsync();
            }
            else
            {
                Snackbar.Add($"Failed to unban {user.DisplayName}. User may not be banned or does not exist.", Severity.Warning);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error unbanning user: {ex.Message}", Severity.Error);
        }
    }

    private async Task ViewUserDetail(long userId)
    {
        var parameters = new DialogParameters<UserDetailDialog>
        {
            { x => x.UserId, userId }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Medium,
            FullWidth = true,
            CloseButton = true,
            CloseOnEscapeKey = true
        };

        var dialog = await DialogService.ShowAsync<UserDetailDialog>("User Details", parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            await RefreshAfterActionAsync();
        }
    }

    // ============================================================================
    // Helpers
    // ============================================================================

    private async Task RefreshAfterActionAsync()
    {
        _tabCounts = await UserManagementService.GetUserTabCountsAsync(
            _chatIds,
            string.IsNullOrWhiteSpace(_searchText) ? null : _searchText);
        await ReloadAllTablesAsync();
        StateHasChanged();
    }

    private async Task ReloadAllTablesAsync()
    {
        if (_activeTable != null) await _activeTable.ReloadServerData();
        if (_taggedTable != null) await _taggedTable.ReloadServerData();
        if (_trustedTable != null) await _trustedTable.ReloadServerData();
        if (_bannedTable != null) await _bannedTable.ReloadServerData();
        if (_kickedTable != null) await _kickedTable.ReloadServerData();
    }

    private static Color GetStatusColor(TelegramUserStatus status) => status switch
    {
        TelegramUserStatus.Trusted => Color.Success,
        TelegramUserStatus.Banned => Color.Error,
        TelegramUserStatus.Warned => Color.Warning,
        TelegramUserStatus.Tagged => Color.Warning,
        TelegramUserStatus.Clean => Color.Info,
        _ => Color.Default
    };

    private static string GetStatusIcon(TelegramUserStatus status) => status switch
    {
        TelegramUserStatus.Trusted => "🟢",
        TelegramUserStatus.Banned => "🔴",
        TelegramUserStatus.Warned => "🟠",
        TelegramUserStatus.Tagged => "🟡",
        TelegramUserStatus.Clean => "🔵",
        _ => ""
    };

    public void Dispose()
    {
        _searchCts.Dispose();
    }
}
