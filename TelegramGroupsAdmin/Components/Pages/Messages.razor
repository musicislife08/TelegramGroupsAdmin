@page "/messages"
@using TelegramGroupsAdmin.Telegram.Services
@using TelegramGroupsAdmin.Telegram.Services.Media
@using TelegramGroupsAdmin.Telegram.Services.Bot
@using TelegramGroupsAdmin.ContentDetection.Models
@using TelegramGroupsAdmin.ContentDetection.Repositories
@using TelegramGroupsAdmin.Core.BackgroundJobs
@using TelegramGroupsAdmin.Core.Extensions
@using TelegramGroupsAdmin.Core.Models
@using TelegramGroupsAdmin.Core.Services
@using TelegramGroupsAdmin.Telegram.Services.Moderation
@using TelegramGroupsAdmin.Core.Utilities
@using TelegramGroupsAdmin.Telegram.Extensions
@inject IMessageHistoryRepository MessageRepository
@inject IMessageQueryService MessageQueryService
@inject IMessageEditService MessageEditService
@inject IMessageTranslationService MessageTranslationService
@inject IManagedChatsRepository ChatsRepository
@inject IJSRuntime Js
@inject IDialogService DialogService
@inject ITelegramBotService BotService
@inject IDetectionResultsRepository DetectionResultsRepository
@inject ITrainingLabelsRepository TrainingLabelsRepository
@inject IJobTriggerService JobTriggerService
@inject IBotModerationService ModerationService
@inject ITelegramUserMappingRepository TelegramMappingRepository
@inject ITelegramUserRepository TelegramUserRepository
@inject NavigationManager NavigationManager
@inject ILogger<Messages> Logger
@inject ISnackbar Snackbar
@inject IMediaRefetchQueueService MediaRefetchQueue
@inject TelegramGroupsAdmin.Core.Services.AI.IAITranslationService TranslationService
@inject IWebBotMessagingService WebBotMessagingService
@inject IWebUserMessagingService WebUserMessagingService
@attribute [Authorize]
@implements IAsyncDisposable

<PageTitle>Messages - TelegramGroupsAdmin</PageTitle>

@* Telegram Desktop Clone Layout *@
<div class="telegram-layout">
    @* Left Sidebar - Chat List *@
    <div class="telegram-sidebar @(_selectedChatId.HasValue ? "has-selection" : "")">
        <div class="sidebar-header">
            <div class="sidebar-title">Chats</div>
            <input type="text"
                   class="sidebar-search"
                   placeholder="Search chats..."
                   value="@_chatSearchText"
                   @oninput="OnChatSearchChanged" />
        </div>

        <ChatList Chats="_filteredChats"
                  SelectedChatId="_selectedChatId"
                  MessageCounts="_chatMessageCounts"
                  LastMessagePreviews="_lastMessagePreviews"
                  OnChatSelected="HandleChatSelected" />
    </div>

    @* Main Chat View *@
    <div class="telegram-main @(_selectedChatId.HasValue ? "active" : "")">
        @if (_selectedChatId.HasValue)
        {
            var selectedChat = _managedChats.FirstOrDefault(c => c.Identity.Id == _selectedChatId.Value);
            if (selectedChat != null)
            {
                @* Chat Header *@
                <ChatHeader ChatName="@selectedChat.Identity.ChatName"
                            ChatIconPath="@selectedChat.ChatIconPath"
                            ChatDescription="@GetChatDescription(selectedChat)"
                            ShowBackButton="true"
                            ShowMenuButton="false"
                            OnBackClicked="HandleBackToChats" />

                @* Messages Container *@
                <div class="messages-container" @ref="_messagesContainer">
                    @if (_loading)
                    {
                        <div class="empty-state">
                            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                        </div>
                    }
                    else if (_allMessages.Any())
                    {
                        <MudVirtualize Items="_allMessages" Context="messageWrapper" OverscanCount="10">
                            <MessageBubbleTelegram Message="messageWrapper.Message"
                                                   ContentCheck="@GetContentCheck(messageWrapper.Message.MessageId)"
                                                   EditCount="@GetEditCount(messageWrapper.Message.MessageId)"
                                                   ShowSpamActions="@(WebUser?.PermissionLevel >= PermissionLevel.GlobalAdmin)"
                                                   DetectionHistory="@messageWrapper.DetectionResults"
                                                   UserTags="@messageWrapper.UserTags"
                                                   UserNotes="@messageWrapper.UserNotes"
                                                   IsCurrentUser="@IsCurrentUserMessage(messageWrapper.Message.User.Id)"
                                                   IsBotMessage="@IsBotMessage(messageWrapper.Message.User.Id)"
                                                   OnImageClick="HandleImageClick"
                                                   OnViewEdits="HandleViewEdits"
                                                   OnMarkAsSpam="HandleMarkAsSpam"
                                                   OnMarkAsHam="HandleMarkAsHam"
                                                   OnViewDetections="HandleViewDetections"
                                                   OnViewUserDetail="ViewUserDetail"
                                                   OnDeleteMessage="HandleDeleteMessage"
                                                   OnTempBan="HandleTempBan"
                                                   OnWarn="HandleWarn"
                                                   OnReplyClick="HandleReplyClick"
                                                   OnReplyToClick="HandleReplyToClick"
                                                   OnEditClick="@((tuple) => HandleEditClick(tuple.MessageId, tuple.MessageText))"
                                                   OnTranslateMessage="HandleTranslateMessage" />
                        </MudVirtualize>

                        @* Scroll Sentinel - triggers loading when scrolled near top (= bottom due to flex-reverse) *@
                        @if (_hasMore)
                        {
                            <div class="scroll-sentinel" @ref="_scrollSentinel">
                                @if (_loadingMore)
                                {
                                    <div class="load-more-container">
                                        <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                                        <span class="loading-text">Loading older messages...</span>
                                    </div>
                                }
                            </div>
                        }
                    }
                    else
                    {
                        <div class="empty-state">
                            <div class="empty-state-icon">
                                <svg viewBox="0 0 24 24">
                                    <path fill="currentColor" d="M20,2H4A2,2 0 0,0 2,4V22L6,18H20A2,2 0 0,0 22,16V4A2,2 0 0,0 20,2M6,9H18V11H6M14,14H6V12H14M18,8H6V6H18" />
                                </svg>
                            </div>
                            <div class="empty-state-text">No messages yet</div>
                            <div class="empty-state-subtext">Messages will appear here as they are received</div>
                        </div>
                    }
                </div>

                <ChatInput IsEnabled="@(_isBotAvailable || _userApiAvailableForChat)"
                           PlaceholderText="@GetChatInputPlaceholder()"
                           MaxMessageLength="@GetMaxMessageLength()"
                           CurrentText="@_editingOriginalText"
                           IsEditMode="@(_isEditingMessageId.HasValue)"
                           ReplyToMessageId="@_replyToMessageId"
                           ReplyToUser="@GetReplyToUser()"
                           ReplyToText="@GetReplyToText()"
                           SendAsUser="@_sendAsUser"
                           UserApiAvailableForChat="@_userApiAvailableForChat"
                           CheckingUserApi="@_checkingUserApi"
                           ToggleDisabledReason="@_toggleDisabledReason"
                           OnSendAsUserChanged="@HandleSendAsUserChanged"
                           OnSendMessage="@SendMessageAsync"
                           OnEditMessage="@EditMessageAsync"
                           OnCancelEdit="@CancelEdit"
                           OnCancelReply="@CancelReply"
                           OnReplyPreviewClick="@HandleReplyClick" />
            }
        }
        else
        {
            @* Empty State - No Chat Selected *@
            <div class="empty-state">
                <div class="empty-state-icon">
                    <svg viewBox="0 0 24 24">
                        <path fill="currentColor" d="M20,2H4A2,2 0 0,0 2,4V22L6,18H20A2,2 0 0,0 22,16V4A2,2 0 0,0 20,2M6,9H18V11H6M14,14H6V12H14M18,8H6V6H18" />
                    </svg>
                </div>
                <div class="empty-state-text">Select a chat to view messages</div>
                <div class="empty-state-subtext">Choose a chat from the list to start viewing its message history</div>
            </div>
        }
    </div>
</div>

@code {
    [CascadingParameter] private WebUserIdentity? WebUser { get; set; }

    // Chat state
    private List<ManagedChatRecord> _managedChats = [];
    private List<ManagedChatRecord> _filteredChats = [];
    private string _chatSearchText = "";
    private long? _selectedChatId;
    private readonly Dictionary<long, int> _chatMessageCounts = new();
    private readonly Dictionary<long, string> _lastMessagePreviews = new();

    // Message state (per-chat) - PERF-APP-1: Use composite model with detection history included
    private List<MessageWithDetectionHistory> _allMessages = [];
    private Dictionary<int, ContentCheckRecord> _contentChecks = new();
    private Dictionary<int, int> _editCounts = new();
    private bool _loading;
    private bool _loadingMore;
    private bool _hasMore = true;
    private bool _needsObserverInit;
    private DateTime _lastUpdate = DateTime.Now;

    // User state
    private HashSet<long> _userTelegramIds = []; // Current user's linked Telegram IDs

    // Send & Edit Messages state
    private bool _isBotAvailable; // Bot messaging available (bot enabled + user has linked account)
    private bool _isUserApiAvailable; // User API available (WTelegram session connected)
    private bool _userApiAvailableForChat; // User API can send to the currently selected chat
    private bool _checkingUserApi; // True while CheckUserApiForChatAsync is running
    private bool _sendAsUser; // Current toggle state: true = personal account, false = bot
    private string? _toggleDisabledReason; // Tooltip text when toggle is disabled
    private long? _botUserId; // Bot's Telegram user ID (for identifying bot messages)
    private string? _linkedUsername; // User's linked Telegram username (for calculating signature length)
    private string? _featureUnavailableReason; // Reason why feature is unavailable (for placeholder text)
    private int? _isEditingMessageId; // Message currently being edited
    private int? _replyToMessageId; // Message being replied to
    private string? _editingOriginalText; // Original text of message being edited

    private int? _highlightMessageId; // Message to scroll to and highlight
    private const int PageSize = 50;

    // Infinite scroll state
    private ElementReference _messagesContainer;
    private ElementReference _scrollSentinel;
    private IJSObjectReference? _infiniteScrollModule;
    private bool _isAutoScrolling; // Prevent infinite scroll from triggering during auto-scroll
    private bool _highlightMessageEnsured; // Track if we've already loaded the highlighted message
    private DotNetObjectReference<Messages>? _dotNetObjectRef; // Reusable reference for JS interop

    // Scroll animation timing - CSS smooth scroll takes 1000-1500ms depending on distance,
    // plus intersection observer delay. Must wait for full animation before re-enabling infinite scroll.
    private const int ScrollAnimationTimeoutMs = 2000;

    protected override async Task OnInitializedAsync()
    {
        if (WebUser is null) return;

        // Load current user's linked Telegram accounts for message alignment
        try
        {
            var mappings = await TelegramMappingRepository.GetByUserIdAsync(WebUser.Id);
            _userTelegramIds = mappings.Select(m => m.TelegramId).ToHashSet();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to load linked Telegram accounts for {User}",
                WebUser.ToLogDebug());
        }

        // Subscribe to real-time updates
        BotService.OnNewMessage += HandleNewMessage;
        BotService.OnMediaUpdated += HandleMediaUpdated;

        // Load managed chats
        await LoadChatsAsync();

        // Parse query string parameters to select chat if specified
        ApplyQueryStringFilters();

        // Check feature availability (bot + user API)
        await CheckFeatureAvailabilityAsync();

        // If a chat was auto-selected from query string, load its messages
        if (_selectedChatId.HasValue)
        {
            await LoadChatMessagesAsync(_selectedChatId.Value);
            await CheckUserApiForChatAsync(_selectedChatId.Value);
        }
    }

    public async ValueTask DisposeAsync()
    {
        // Unsubscribe from events
        BotService.OnNewMessage -= HandleNewMessage;
        BotService.OnMediaUpdated -= HandleMediaUpdated;

        // Dispose JavaScript interop resources
        if (_infiniteScrollModule is not null)
            await _infiniteScrollModule.DisposeAsync();
        _dotNetObjectRef?.Dispose();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Initialize IntersectionObserver for infinite scroll
        // Import module on first render, but re-initialize observer whenever a chat is loaded with more pages
        if (firstRender)
        {
            try
            {
                _infiniteScrollModule = await Js.InvokeAsync<IJSObjectReference>("import", "./js/infinite-scroll.js");
                _dotNetObjectRef = DotNetObjectReference.Create(this);
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Failed to import infinite scroll module");
            }
        }

        // (Re)initialize observer when needed (chat loaded with _hasMore = true)
        if (_needsObserverInit && _infiniteScrollModule != null && _dotNetObjectRef != null && _selectedChatId.HasValue && _hasMore)
        {
            try
            {
                await _infiniteScrollModule.InvokeVoidAsync("initializeIntersectionObserver",
                    _scrollSentinel,
                    _dotNetObjectRef);
                _needsObserverInit = false;
                Logger.LogDebug("Infinite scroll observer initialized for chat {ChatId}", _selectedChatId);
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Failed to initialize intersection observer for infinite scroll");
            }
        }

        // Handle auto-scroll to highlighted message (must be done in OnAfterRenderAsync for JS interop)
        if (_highlightMessageId.HasValue && !_loading && _isAutoScrolling)
        {
            try
            {
                var targetMessageId = _highlightMessageId.Value;

                // Clear immediately to prevent re-entry if StateHasChanged() is called during scroll
                _highlightMessageId = null;

                // Find the index of the message in filtered list
                var messageIndex = _allMessages.FindIndex(mw => mw.Message.MessageId == targetMessageId);

                if (messageIndex >= 0)
                {
                    // Scroll container to approximate position to trigger MudVirtualize rendering
                    await Js.InvokeVoidAsync("scrollMessageContainer", messageIndex, _allMessages.Count);
                    await Task.Delay(200); // Wait for MudVirtualize to render
                    await Js.InvokeVoidAsync("scrollToMessage", targetMessageId);
                    Logger.LogInformation("Successfully scrolled to highlighted message: {MessageId}", targetMessageId);
                }
                else
                {
                    Logger.LogWarning("Highlighted message {MessageId} not found in filtered messages", targetMessageId);
                    Snackbar.Add($"Message {targetMessageId} not found in current view", Severity.Warning);
                }

                // Wait for scroll animation to complete, then re-enable infinite scroll
                await Task.Delay(ScrollAnimationTimeoutMs);
                _isAutoScrolling = false;
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Failed to auto-scroll to highlighted message");
                Snackbar.Add("Could not scroll to message", Severity.Error);
                _highlightMessageId = null;
                _isAutoScrolling = false;
            }
        }

        await base.OnAfterRenderAsync(firstRender);
    }

    /// <summary>
    /// Ensures the highlighted message is loaded in the current view (loads from DB if needed)
    /// Does NOT perform scrolling - that happens in OnAfterRenderAsync where JS interop is allowed
    /// </summary>
    private async Task EnsureHighlightedMessageLoadedAsync(int targetMessageId)
    {
        // Prevent duplicate calls (e.g., from Blazor prerendering)
        if (_highlightMessageEnsured)
            return;

        try
        {
            // Check if target message is in the filtered list
            var targetMessage = _allMessages.FirstOrDefault(mw => mw.Message.MessageId == targetMessageId);

            if (targetMessage == null)
            {
                // Message not loaded yet, try to load it
                var message = await MessageRepository.GetMessageAsync(targetMessageId, _selectedChatId!.Value);
                if (message == null)
                {
                    Logger.LogWarning("Highlighted message {MessageId} not found in database", targetMessageId);
                    Snackbar.Add($"Message {targetMessageId} not found", Severity.Warning);
                    _highlightMessageId = null; // Clear since it doesn't exist
                    return;
                }

                // Add to the list if not already there (wrapped in MessageWithDetectionHistory)
                if (_allMessages.All(mw => mw.Message.MessageId != targetMessageId))
                {
                    var messageWrapper = new MessageWithDetectionHistory { Message = message };

                    // Insert in chronological order (messages are sorted newest-first)
                    var insertIndex = _allMessages.FindIndex(mw => mw.Message.Timestamp < message.Timestamp);
                    if (insertIndex >= 0)
                    {
                        _allMessages.Insert(insertIndex, messageWrapper);
                    }
                    else
                    {
                        _allMessages.Add(messageWrapper);
                    }

                    // Load metadata for this message
                    int[] messageIds = [targetMessageId];
                    var contentChecks = await MessageQueryService.GetContentChecksForMessagesAsync(_selectedChatId!.Value, messageIds);
                    var editCounts = await MessageEditService.GetEditCountsForMessagesAsync(_selectedChatId!.Value, messageIds);

                    foreach (var kvp in contentChecks)
                        _contentChecks[kvp.Key] = kvp.Value;
                    foreach (var kvp in editCounts)
                        _editCounts[kvp.Key] = kvp.Value;

                    // Load detection history for Admin+ users (now included in wrapper)
                    if (WebUser!.PermissionLevel >= PermissionLevel.GlobalAdmin)
                    {
                        var history = await DetectionResultsRepository.GetByMessageIdAsync(targetMessageId, _selectedChatId!.Value);
                        messageWrapper.DetectionResults.AddRange(history);
                    }
                }
            }

            // Mark as ensured to prevent duplicate calls
            _highlightMessageEnsured = true;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load highlighted message {MessageId}", targetMessageId);
            Snackbar.Add($"Could not load message {targetMessageId}", Severity.Error);
            _highlightMessageId = null; // Clear on error to prevent infinite retry
            _highlightMessageEnsured = true; // Prevent retry
        }
    }

    // ReSharper disable once AsyncVoidMethod
    private async void HandleNewMessage(MessageRecord message)
    {
        // CRITICAL: Must use InvokeAsync because HistoryBot runs on background thread
        await InvokeAsync(async () =>
        {
            try
            {
                // Update sidebar preview and message count for this chat
                var preview = message.MediaType?.ToDisplayName()
                              ?? message.MessageText
                              ?? (!string.IsNullOrEmpty(message.PhotoFileId) ? "Photo" : "Message");
                _lastMessagePreviews[message.Chat.Id] = preview;
                _chatMessageCounts[message.Chat.Id] = _chatMessageCounts.GetValueOrDefault(message.Chat.Id) + 1;

                // Only add to message list if it belongs to the currently selected chat
                if (!_selectedChatId.HasValue || message.Chat.Id != _selectedChatId.Value)
                {
                    StateHasChanged(); // Still re-render for sidebar update
                    return;
                }

                // Capture scroll state before adding message
                var scrollState = await Js.InvokeAsync<ScrollState>("captureScrollState", _messagesContainer);

                // Fetch enriched message with user photo and reply data from database view
                var enrichedMessage = await MessageQueryService.GetMessageByIdAsync(message);

                // Add to our list at the beginning (most recent first) wrapped in MessageWithDetectionHistory
                // Use enriched message if available, otherwise fall back to original
                _allMessages.Insert(0, new MessageWithDetectionHistory { Message = enrichedMessage ?? message });

                // Load spam check for this new message if it exists
                int[] messageIds = [message.MessageId];
                var newContentChecks = await MessageQueryService.GetContentChecksForMessagesAsync(_selectedChatId!.Value, messageIds);
                foreach (var kvp in newContentChecks)
                {
                    _contentChecks[kvp.Key] = kvp.Value;
                }

                // Load edit count for this message
                var newEditCounts = await MessageEditService.GetEditCountsForMessagesAsync(_selectedChatId!.Value, messageIds);
                foreach (var kvp in newEditCounts)
                {
                    _editCounts[kvp.Key] = kvp.Value;
                }

                // Trigger re-render
                StateHasChanged();

                // Wait for browser to complete render cycle, then restore scroll
                await Js.InvokeVoidAsync("restoreScrollStateAfterRender", _messagesContainer, scrollState);

                Logger.LogDebug("Added new real-time message {MessageId} to chat {ChatId} view",
                    message.MessageId, message.Chat.Id);
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Failed to handle new message {MessageId} from real-time update", message.MessageId);
            }
        });
    }

    // ReSharper disable once AsyncVoidMethod
    private async void HandleMediaUpdated(int messageId, MediaType mediaType)
    {
        // CRITICAL: Must use InvokeAsync because worker runs on background thread
        await InvokeAsync(async () =>
        {
            try
            {
                Logger.LogDebug("SignalR notification received for message {MessageId} type {MediaType}", messageId, mediaType);

                // Reload the message from database to get updated media_local_path
                var updatedMessage = await MessageRepository.GetMessageAsync(messageId, _selectedChatId!.Value);
                if (updatedMessage == null)
                {
                    Logger.LogWarning("Updated message {MessageId} not found in database", messageId);
                    return;
                }

                // Only update if message belongs to currently selected chat
                if (!_selectedChatId.HasValue || updatedMessage.Chat.Id != _selectedChatId.Value)
                {
                    Logger.LogTrace("Ignoring media update for message {MessageId} from chat {ChatId} (currently viewing chat {SelectedChatId})",
                        messageId, updatedMessage.Chat.Id, _selectedChatId);
                    return;
                }

                // Find and replace in our list (Message is init-only)
                var index = _allMessages.FindIndex(m => m.Message.MessageId == messageId);
                if (index >= 0)
                {
                    var detectionResults = _allMessages[index].DetectionResults;
                    _allMessages[index] = new MessageWithDetectionHistory
                    {
                        Message = updatedMessage,
                        DetectionResults = detectionResults
                    };

                    StateHasChanged();

                    Logger.LogDebug("UI refreshed for message {MessageId} after media download via SignalR", messageId);
                }
                else
                {
                    Logger.LogWarning("Message {MessageId} not found in _allMessages list", messageId);
                }
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Error handling media update for message {MessageId}", messageId);
            }
        });
    }

    private async Task LoadChatsAsync()
    {
        try
        {
            // Load chats accessible to this user (filtered by permission level)
            _managedChats = await ChatsRepository.GetUserAccessibleChatsAsync(
                WebUser!.Id,
                WebUser.PermissionLevel);
            ApplyChatFilter();

            // Calculate message counts for each chat
            await CalculateChatStatisticsAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load managed chats");
        }
    }

    private void OnChatSearchChanged(ChangeEventArgs e)
    {
        _chatSearchText = e.Value?.ToString() ?? "";
        ApplyChatFilter();
    }

    private void ApplyChatFilter()
    {
        if (string.IsNullOrWhiteSpace(_chatSearchText))
        {
            _filteredChats = _managedChats;
        }
        else
        {
            _filteredChats = _managedChats
                .Where(c => c.Identity.ChatName?.Contains(_chatSearchText, StringComparison.OrdinalIgnoreCase) == true)
                .ToList();
        }
    }

    private async Task CalculateChatStatisticsAsync()
    {
        try
        {
            foreach (var chat in _managedChats)
            {
                // Get total message count for this chat
                var totalCount = await MessageRepository.GetMessageCountByChatIdAsync(chat.Identity.Id);
                _chatMessageCounts[chat.Identity.Id] = totalCount;

                // Get last message preview (only fetch 1 message for preview)
                if (totalCount > 0)
                {
                    var lastMessages = await MessageQueryService.GetMessagesByChatIdAsync(chat.Identity.Id, limit: 1);
                    if (lastMessages.Any())
                    {
                        var lastMessage = lastMessages.First();
                        var hasPhoto = !string.IsNullOrEmpty(lastMessage.PhotoFileId);
                        var preview = lastMessage.MediaType?.ToDisplayName()
                                      ?? lastMessage.MessageText
                                      ?? (hasPhoto ? "Photo" : "Message");
                        _lastMessagePreviews[chat.Identity.Id] = preview;
                    }
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to calculate chat statistics");
        }
    }

    private async Task HandleChatSelected(long chatId)
    {
        _selectedChatId = chatId;
        await LoadChatMessagesAsync(chatId);
        await CheckUserApiForChatAsync(chatId);
    }

    /// <summary>
    /// Check if the admin's personal Telegram account can send to this specific chat.
    /// Updates toggle state accordingly — defaults to user mode when available, falls back to bot.
    /// </summary>
    private async Task CheckUserApiForChatAsync(long chatId)
    {
        _checkingUserApi = true;

        try
        {
            if (!_isUserApiAvailable || WebUser == null)
            {
                _userApiAvailableForChat = false;
                _sendAsUser = false;
                _toggleDisabledReason = !_isUserApiAvailable
                    ? "Connect your Telegram account in Settings"
                    : null;
                return;
            }

            var chatResult = await WebUserMessagingService.CanSendToChatAsync(WebUser, chatId);
            _userApiAvailableForChat = chatResult.CanSend;

            if (!chatResult.CanSend)
            {
                _sendAsUser = false;
                _toggleDisabledReason = chatResult.UnavailableReason ?? "Not available for this chat";
            }
            else
            {
                _sendAsUser = true; // Default to user mode when available
                _toggleDisabledReason = null;
            }
        }
        finally
        {
            _checkingUserApi = false;
        }
    }

    private void HandleBackToChats()
    {
        _selectedChatId = null;
        _allMessages.Clear();
        StateHasChanged();
    }

    private async Task LoadChatMessagesAsync(long chatId)
    {
        // PERF-APP-3: Set loading state without intermediate render
        _loading = true;
        _hasMore = true;
        _allMessages.Clear();
        _contentChecks.Clear();
        _editCounts.Clear();
        _highlightMessageEnsured = false; // Reset highlight state for new chat

        try
        {
            var firstPage = await LoadMessagesPageAsync(chatId);

            _allMessages = firstPage;
            _hasMore = firstPage.Count >= PageSize;

            if (_allMessages.Any())
                await LoadMetadataForMessagesAsync(_allMessages, replace: true);

            _lastUpdate = DateTime.Now;

            await QueueMissingMediaForRefetchAsync();

            // Request observer initialization if there are more pages to load
            if (_hasMore)
            {
                _needsObserverInit = true;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unexpected error loading messages for chat {ChatId}", chatId);
        }
        finally
        {
            // PERF-APP-3: Single render after all data loaded
            _loading = false;

            // Set auto-scroll flag BEFORE StateHasChanged to prevent intersection observer from triggering
            if (_highlightMessageId.HasValue)
            {
                _isAutoScrolling = true;
                // Ensure the message is loaded (if not in current view, fetch from DB)
                // Actual scrolling happens in OnAfterRenderAsync where JS interop is allowed
                await EnsureHighlightedMessageLoadedAsync(_highlightMessageId.Value);
            }

            StateHasChanged();
        }
    }

    private string GetChatDescription(ManagedChatRecord chat)
    {
        // Could show member count, last active, etc.
        return chat.IsAdmin ? "Bot is admin" : "Bot is member";
    }

    [JSInvokable]
    public async Task LoadOlderMessagesAsync()
    {
        // Don't trigger infinite scroll during auto-scroll to highlighted message
        if (_isAutoScrolling || _loadingMore || !_hasMore || !_selectedChatId.HasValue)
            return;

        // PERF-APP-3: Set loading state without intermediate render
        _loadingMore = true;

        try
        {
            // Get the timestamp of the oldest message currently loaded
            var oldestMessage = _allMessages.LastOrDefault();
            if (oldestMessage == null)
            {
                _hasMore = false;
                return;
            }

            var olderMessages = await LoadMessagesPageAsync(
                _selectedChatId.Value, beforeTimestamp: oldestMessage.Message.Timestamp);

            if (olderMessages.Any())
            {
                _allMessages.AddRange(olderMessages);
                await LoadMetadataForMessagesAsync(olderMessages, replace: false);
                _hasMore = olderMessages.Count >= PageSize;

                Logger.LogDebug("Loaded {Count} older messages, hasMore: {HasMore}", olderMessages.Count, _hasMore);
            }
            else
            {
                _hasMore = false;
                Logger.LogDebug("No more older messages to load");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load older messages for chat {ChatId}", _selectedChatId);
        }
        finally
        {
            // PERF-APP-3: Single render after all data loaded
            _loadingMore = false;
            StateHasChanged();
        }
    }

