    /// <summary>
    /// Loads edit counts and content checks for a batch of messages.
    /// When <paramref name="replace"/> is true, replaces the dictionaries; otherwise merges into them.
    /// </summary>
    private async Task LoadMetadataForMessagesAsync(List<MessageWithDetectionHistory> messages, bool replace)
    {
        var messageIds = messages.Select(m => m.Message.MessageId).ToList();

        if (WebUser!.PermissionLevel >= PermissionLevel.GlobalAdmin)
        {
            var editCounts = await MessageEditService.GetEditCountsForMessagesAsync(_selectedChatId!.Value, messageIds);
            if (replace)
            {
                _editCounts = editCounts;
            }
            else
            {
                foreach (var kvp in editCounts)
                    _editCounts[kvp.Key] = kvp.Value;
            }
        }
        else
        {
            var editCountsTask = MessageEditService.GetEditCountsForMessagesAsync(_selectedChatId!.Value, messageIds);
            var contentChecksTask = MessageQueryService.GetContentChecksForMessagesAsync(_selectedChatId!.Value, messageIds);
            await Task.WhenAll(editCountsTask, contentChecksTask);

            var editCounts = await editCountsTask;
            var contentChecks = await contentChecksTask;

            if (replace)
            {
                _editCounts = editCounts;
                _contentChecks = contentChecks;
            }
            else
            {
                foreach (var kvp in editCounts)
                    _editCounts[kvp.Key] = kvp.Value;
                foreach (var kvp in contentChecks)
                    _contentChecks[kvp.Key] = kvp.Value;
            }
        }
    }

    private ContentCheckRecord? GetContentCheck(int messageId)
    {
        // PERF-APP-1: Use detection results already loaded via Include() instead of separate dictionary
        var wrapper = _allMessages.FirstOrDefault(mw => mw.Message.MessageId == messageId);
        if (wrapper?.DetectionResults.Any() != true)
        {
            // Fallback to dictionary for backward compatibility (messages loaded without detection history)
            _contentChecks.TryGetValue(messageId, out var fallback);
            return fallback;
        }

        // Use latest detection result (already ordered DESC by DetectedAt in repository)
        var latest = wrapper.DetectionResults.First();
        return new ContentCheckRecord(
            Id: latest.Id,
            CheckTimestamp: latest.DetectedAt,
            UserId: latest.UserId,
            ContentHash: wrapper.Message.ContentHash,
            IsSpam: latest.IsSpam,
            Confidence: Math.Abs(latest.NetConfidence),
            Reason: latest.Reason,
            CheckType: latest.DetectionMethod,
            MatchedMessageId: messageId
        );
    }

    private int GetEditCount(int messageId)
    {
        _editCounts.TryGetValue(messageId, out var count);
        return count;
    }

