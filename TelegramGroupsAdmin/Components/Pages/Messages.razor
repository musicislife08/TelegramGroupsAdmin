    /// <summary>
    /// Check if bot and user API messaging features are available.
    /// </summary>
    private async Task CheckFeatureAvailabilityAsync()
    {
        if (WebUser == null)
        {
            _featureUnavailableReason = "Not authenticated";
            return;
        }

        // Check bot availability
        var botResult = await WebBotMessagingService.CheckFeatureAvailabilityAsync(WebUser);
        _isBotAvailable = botResult.IsAvailable;
        _botUserId = botResult.BotUserId;
        _linkedUsername = botResult.LinkedUsername;
        _featureUnavailableReason = botResult.UnavailableReason;

        // Check user API availability (WTelegram session connected)
        var userResult = await WebUserMessagingService.CheckFeatureAvailabilityAsync(WebUser);
        _isUserApiAvailable = userResult.IsAvailable;

        if (!_isUserApiAvailable)
        {
            _toggleDisabledReason = userResult.UnavailableReason ?? "User API not available";
        }
    }

    /// <summary>
    /// Calculate maximum message length accounting for signature in bot mode.
    /// User mode: full 4096 limit (no signature). Bot mode: reduced by signature length.
    /// </summary>
    private int GetMaxMessageLength()
    {
        const int telegramLimit = 4096;

        // User mode — no signature, full limit
        if (_sendAsUser)
            return telegramLimit;

        // Bot mode — reduce by signature length
        if (!string.IsNullOrEmpty(_linkedUsername))
        {
            var signatureLength = 3 + _linkedUsername.Length; // "\n\n—" + username
            return telegramLimit - signatureLength;
        }

        return telegramLimit;
    }

    /// <summary>
    /// Send message — routes through user API or bot based on toggle state.
    /// </summary>
    private async Task SendMessageAsync(string text)
    {
        if (!_selectedChatId.HasValue || WebUser == null)
        {
            Snackbar.Add("Not authenticated", Severity.Error);
            return;
        }

        if (_sendAsUser)
        {
            var result = await WebUserMessagingService.SendMessageAsync(
                WebUser, _selectedChatId.Value, text, _replyToMessageId);

            if (result.Success)
            {
                _replyToMessageId = null;
                // Bot sees this as a normal incoming message — UI updates via HandleNewMessage event
            }
            else
            {
                Snackbar.Add($"Failed to send: {result.ErrorMessage}", Severity.Error);
            }
        }
        else
        {
            var result = await WebBotMessagingService.SendMessageAsync(
                WebUser, _selectedChatId.Value, text, _replyToMessageId);

            if (result.Success)
            {
                _replyToMessageId = null;
                Snackbar.Add("Message sent", Severity.Success);

                // Bot doesn't receive updates for its own messages — manual refresh required
                await LoadChatMessagesAsync(_selectedChatId.Value);
            }
            else
            {
                Snackbar.Add($"Failed to send: {result.ErrorMessage}", Severity.Error);
            }
        }
    }

    /// <summary>
    /// Edit message — routes through user API or bot based on toggle state.
    /// </summary>
    private async Task EditMessageAsync(string text)
    {
        if (!_isEditingMessageId.HasValue || !_selectedChatId.HasValue || WebUser == null)
        {
            Snackbar.Add("Not authenticated", Severity.Error);
            return;
        }

        if (_sendAsUser)
        {
            var result = await WebUserMessagingService.EditMessageAsync(
                WebUser, _selectedChatId.Value, _isEditingMessageId.Value, text);

            if (result.Success)
            {
                _isEditingMessageId = null;
                _editingOriginalText = null;
                // Bot sees this edit — UI updates via event
            }
            else
            {
                Snackbar.Add($"Failed to edit: {result.ErrorMessage}", Severity.Error);
            }
        }
        else
        {
            var result = await WebBotMessagingService.EditMessageAsync(
                WebUser, _selectedChatId.Value, _isEditingMessageId.Value, text);

            if (result.Success)
            {
                _isEditingMessageId = null;
                _editingOriginalText = null;
                Snackbar.Add("Message edited", Severity.Success);

                // Bot doesn't receive updates for its own edits — manual refresh
                await LoadChatMessagesAsync(_selectedChatId.Value);
            }
            else
            {
                Snackbar.Add($"Failed to edit: {result.ErrorMessage}", Severity.Error);
            }
        }
    }

    private void HandleSendAsUserChanged(bool sendAsUser)
    {
        _sendAsUser = sendAsUser;
    }

    /// <summary>
    /// Handle edit button click from MessageBubbleTelegram
    /// </summary>
    private void HandleEditClick(int messageId, string messageText)
    {
        _isEditingMessageId = messageId;
        _editingOriginalText = messageText;
        StateHasChanged();

        Logger.LogDebug("Started editing message {MessageId}", messageId);
    }

    /// <summary>
    /// Handle reply button click from MessageBubbleTelegram
    /// </summary>
    private void HandleReplyToClick(int messageId)
    {
        _replyToMessageId = messageId;
        StateHasChanged();

        Logger.LogDebug("Started reply to message {MessageId}", messageId);
    }

    /// <summary>
    /// Cancel edit mode
    /// </summary>
    private void CancelEdit()
    {
        _isEditingMessageId = null;
        _editingOriginalText = null;
        StateHasChanged();
    }

    /// <summary>
    /// Cancel reply mode
    /// </summary>
    private void CancelReply()
    {
        _replyToMessageId = null;
        StateHasChanged();
    }

    /// <summary>
    /// Get placeholder text based on state
    /// </summary>
    private string GetChatInputPlaceholder()
    {
        if (!_isBotAvailable && !_userApiAvailableForChat)
            return _featureUnavailableReason ?? "Messaging unavailable";

        if (_isEditingMessageId.HasValue)
            return "Edit message...";

        return _sendAsUser ? "Message as you..." : "Message as bot...";
    }

    /// <summary>
    /// Get reply-to user display name
    /// </summary>
    private string? GetReplyToUser()
    {
        if (!_replyToMessageId.HasValue)
            return null;

        var replyMessage = _allMessages.FirstOrDefault(mw => mw.Message.MessageId == _replyToMessageId.Value);
        if (replyMessage == null)
            return null;

        return replyMessage.Message.User.DisplayName;
    }

    /// <summary>
    /// Get reply-to message text
    /// </summary>
    private string? GetReplyToText()
    {
        if (!_replyToMessageId.HasValue)
            return null;

        var replyMessage = _allMessages.FirstOrDefault(mw => mw.Message.MessageId == _replyToMessageId.Value);
        return replyMessage?.Message.MessageText;
    }

    /// <summary>
    /// Check if message is from the bot
    /// </summary>
    private bool IsBotMessage(long userId)
    {
        return _botUserId.HasValue && userId == _botUserId.Value;
    }
}
