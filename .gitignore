bin/
obj/
# Workaround: dotnet-ef 10.0.2-10.0.3 creates literal backslash paths on macOS/Linux
# See https://github.com/dotnet/efcore/issues/37506 — fixed in 10.0.4
**/bin\\*
**/obj\\*
/packages/
riderModule.iml
.DS_Store
tg-spam/
compose/*
*.DotSettings.user

# Tesseract language data (large binary files - baked into Docker image instead)
tessdata/

# FastText language models (large binary files - baked into Docker image instead)
**/lang-models/

# Runtime data files (backups, media, etc.)
**/*.tar.gz

# === SECURITY: Dotnet Secret Files ===
# Never commit these - they contain API keys, tokens, connection strings

# Launch settings (local dev environment config)
**/Properties/launchSettings.json
launchSettings.json

# User secrets (dotnet user-secrets tool)
**/secrets.json

# HTTP client environment files (JetBrains Rider)
http-client.private.env.json
**/http-client.private*.json
**/*.http

# appsettings with secrets (should use env vars instead)
appsettings.Development.json
appsettings.Local.json
appsettings.*.local.json

# Environment files
.env
.env.local
.env.*.local
!.env.example

# Docker secrets
docker-compose.override.yml
compose.override.yml

# Azure/cloud secrets
**/azure-*.json
**/aws-*.json

# Certificate files
**/*.pfx
**/*.p12
**/*.key
**/*.pem
tmp/

# Playwright test results
**/TestResults/
